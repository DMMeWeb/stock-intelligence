SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_dev_dashboard_client_id
SHOPIFY_CLIENT_SECRET=your_dev_dashboard_client_secret
# Optional: only use this if you have an old legacy custom app token.
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_your_token_here
SHOPIFY_API_VERSION=2026-04
SHOPIFY_ORDER_LOOKBACK_DAYS=92
APP_PASSWORD=change-this-password
APP_SESSION_SECRET=change-this-long-random-secret
SYNC_TIME=08:00
SYNC_ON_STARTUP=true
# Railway sets PORT automatically. For local use only:
# PORT=4173
